# ==========================================
# Telegram Bot Configuration
# ==========================================

# Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram API credentials from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# ==========================================
# Security
# ==========================================

# Encryption key for sessions (min 32 chars, random string)
ENCRYPTION_KEY=your_very_long_random_encryption_key_here_32chars

# ==========================================
# Database & Sessions — PERSISTENCE NOTICE
# ==========================================
#
# ⚠️  IMPORTANT for Railway / Docker / any cloud deployment:
#
# Both DB_PATH and SESSIONS_DIR MUST point to a persistent volume.
# If they point to the container's ephemeral filesystem, all accounts
# and sessions will be lost on every deployment or restart.
#
# Railway example (attach a volume mounted at /data):
#   DB_PATH=./data/accounts.db      ← relative paths work fine for
#   SESSIONS_DIR=./sessions            local/Termux environments
#
#   DB_PATH=/data/accounts.db       ← use absolute paths on Railway
#   SESSIONS_DIR=/data/sessions        after mounting a volume at /data
#
# The session restore service automatically recreates missing session
# files from the encrypted_session column stored in the SQLite database,
# so as long as the database file itself is on a persistent volume the
# sessions directory can be reconstructed after a fresh deployment.

# SQLite database path (must be on a persistent volume in production)
DB_PATH=./data/accounts.db

# Directory where encrypted session files are stored
# (must be on a persistent volume in production)
SESSIONS_DIR=./sessions

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=info
LOG_DIR=./logs
